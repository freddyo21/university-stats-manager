{
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "/api/$1"
        },
        {
            "src": "/((?!api|src|node_modules|@vite|@id|@fs|index\\.html|favicon\\.svg).*\\.[^/]*)",
            "dest": "/$1"
        },
        {
            "src": "/((?!api|src|node_modules|@vite|@id|@fs|index\\.html|favicon\\.svg)[^.]*)",
            "dest": "/index.html"
        }
    ]
}